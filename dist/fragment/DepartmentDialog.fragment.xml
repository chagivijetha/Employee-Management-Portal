<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog title="Department Dialog" contentWidth="450px">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                <f:content>
                    <Label text="Department Name" required="true"/>
                    <Input value="{dialog>/name}" />
                    
                    <Label text="Manager Name" />
                    <Input value="{dialog>/managerName}" />
                    
                    <Label text="Budget" />
                    <Input value="{dialog>/budget}" />
                    
                    <Label text="Description" />
                    <TextArea value="{dialog>/description}" rows="3" />
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press=".onSaveDepartment" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCancelDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
