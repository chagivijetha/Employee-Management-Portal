<mvc:View
    controllerName="my.sample.app.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">
    <Page title="Employee Portal Login" showHeader="true" showNavButton="false">
        <content>
            <VBox alignItems="Center" justifyContent="Center" class="sapUiLargeMarginTop">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout" title="Sign In" width="400px" class="sapUiResponsiveMargin">
                    <f:content>
                        <Label text="Username" />
                        <Input id="usernameInput" placeholder="Enter Username (e.g. admin)" />
                        <Label text="Password" />
                        <Input id="passwordInput" type="Password" placeholder="Enter Password" />
                    </f:content>
                </f:SimpleForm>
                <Button text="Login" type="Emphasized" press=".onLoginPress" width="200px" class="sapUiTinyMarginTop"/>
            </VBox>
        </content>
    </Page>
</mvc:View>
