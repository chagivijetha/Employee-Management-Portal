<mvc:View
    controllerName="my.sample.app.controller.DepartmentList"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <Page title="Departments" showNavButton="true" navButtonPress=".onNavBack">
        <headerContent>
            <Button icon="sap-icon://add" text="Create Department" press=".onAddDepartment" visible="{= ${session>/user/role} === 'Admin'}"/>
        </headerContent>
        <content>
            <Table id="departmentTable" items="{path: '/departments', sorter: {path: 'name'}}" mode="SingleSelectMaster" itemPress=".onDepartmentPress">
                <columns>
                    <Column>
                        <Text text="Department Name" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Manager" />
                    </Column>
                    <Column minScreenWidth="Desktop" demandPopin="true" hAlign="End">
                        <Text text="Budget (USD)" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onDepartmentPress">
                        <cells>
                            <ObjectIdentifier title="{name}" text="{id}" />
                            <Text text="{managerName}" />
                            <Text text="{budget}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
