<mvc:View
    controllerName="my.sample.app.controller.EmployeeList"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <Page title="Employee Directory" showNavButton="true" navButtonPress=".onNavBack">
        <headerContent>
            <Button icon="sap-icon://add" text="Add Employee" press=".onAddEmployee" visible="{= ${session>/user/role} !== 'Employee'}"/>
        </headerContent>
        <content>
            <Table id="employeeTable" items="{path: '/employees', sorter: {path: 'lastName'}}" mode="SingleSelectMaster" itemPress=".onEmployeePress">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Employees ({= ${/employees}.length })" level="H2"/>
                        <ToolbarSpacer />
                        <Button icon="sap-icon://excel-attachment" press=".onExport" tooltip="Download to Excel"/>
                        <SearchField id="searchField" width="30%" search=".onSearch" placeholder="Search by Name or Department..."/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Text text="Name" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Department" />
                    </Column>
                    <Column minScreenWidth="Desktop" demandPopin="true">
                        <Text text="Position" />
                    </Column>
                    <Column>
                        <Text text="Status" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onEmployeePress">
                        <cells>
                            <ObjectIdentifier title="{firstName} {lastName}" text="{id}" />
                            <Text text="{department}" />
                            <Text text="{position}" />
                            <ObjectStatus text="{status}" state="{= ${status} === 'Active' ? 'Success' : 'Error' }" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
