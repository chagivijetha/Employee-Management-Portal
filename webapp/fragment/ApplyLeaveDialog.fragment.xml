<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog title="Apply for Leave" contentWidth="400px">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                <f:content>
                    <Label text="Leave Type" required="true"/>
                    <Select selectedKey="{dialog>/type}">
                        <core:Item key="Annual Leave" text="Annual Leave" />
                        <core:Item key="Sick Leave" text="Sick Leave" />
                        <core:Item key="Unpaid Leave" text="Unpaid Leave" />
                    </Select>
                    
                    <Label text="Start Date" required="true"/>
                    <DatePicker value="{dialog>/startDate}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" />
                    
                    <Label text="End Date" required="true"/>
                    <DatePicker value="{dialog>/endDate}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" />
                    
                    <Label text="Reason" />
                    <TextArea value="{dialog>/reason}" rows="3" />
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button text="Submit Request" type="Emphasized" press=".onSubmitLeave" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCancelDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
